  "item": [
    {
      "name": "businesses",
      "item": [
        {
          "name": "GET /businesses - fetch list (expect 200)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Capture first businessId', () => {",
                  "  const body = pm.response.json();",
                  "  const id = body.businesses[0]._id;",
                  "  pm.collectionVariables.set('businessId', id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/businesses?page=1",
              "host": ["{{baseUrl}}"],
              "path": ["businesses"],
              "query": [{ "key": "page", "value": "1" }]
            }
          }
        }
      ]
    },
    {
